@using MudBlazor.Extensions.Core
@inherits LayoutComponentBase


<MudThemeProvider @bind-IsDarkMode="@_isDark" Theme="@ClientTheme.CurrentTheme" />
<MudPopoverProvider/>
<MudDialogProvider />
<MudExTaskBar BorderColor="MudExColor.Warning" HideContentWhenCollapsed="true"/>
<MudSnackbarProvider />

<MudLayout>
    @Body
</MudLayout>

@code {
    // Fall back to the main layout's mode when navigated from within the app, otherwise default to dark.
    private bool _isDark = MainLayout.Instance?.IsDark ?? true;
}
