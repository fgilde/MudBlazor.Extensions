@inherits BasePage

@using MudBlazor.Extensions.Helper

<MudDialog Class="mud-ex-dialog-initial_">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3"/> @L["Sample Dialog"]
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTabs Elevation="1" Rounded="true">
            <MudTabPanel Text="Item One" ToolTip="ToolTip One">
                <div style="height: 100px">
                    <MudText>@L["Item One"]</MudText>
                </div>
            </MudTabPanel>
            <MudTabPanel Text="@L["Item Two"]" ToolTip="@L["ToolTip Two"]">
                <MudText>@L["Item Two"]</MudText>
            </MudTabPanel>
            <MudTabPanel Text="@L["Item Three"]" ToolTip="@L["ToolTip Three"]">
                <MudText>@L["Item Three"]</MudText>
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@L["Cancel"]</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit">@L["Ok"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    
    async Task Submit() => await MudDialog.CloseAnimatedIfAsync(DialogResult.Ok(true));
    async Task Cancel() => await MudDialog.CancelAnimatedIfAsync();
}